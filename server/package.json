{
  "name": "mahadev-server",
  "version": "1.0.0",
  "description": "Mahadev Inn SaaS Backend Server",
  "main": "dist/main.js",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "postinstall": "prisma generate",
    "prisma:gen": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed": "ts-node prisma/seed.ts",
    "seed:tsx": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "clear-cache": "rimraf dist && rimraf node_modules/.cache",
    "dev:clean": "npm run clear-cache && npm run start:dev",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "pm2:start": "pm2 start dist/main.js --name mahadev-server",
    "pm2:stop": "pm2 stop mahadev-server",
    "pm2:restart": "pm2 restart mahadev-server",
    "pm2:logs": "pm2 logs mahadev-server",
    "pm2:status": "pm2 list"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.7",
    "@nestjs/core": "^10.4.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.7",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "file-saver": "^2.0.5",
    "html-pdf": "^3.0.1",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "mysql2": "^3.22.6",
    "nanoid": "^5.0.7",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "puppeteer-core": "^25.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/html-pdf": "^3.0.3",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}

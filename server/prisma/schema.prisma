// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====
enum Role {
  OWNER
  MANAGER
  VIEWER
  ADMIN
}

enum Branch {
  Pokhara
  Kathmandu
  Bhairawaha
  Kathmandu1
  Kathmandu2
}

enum BookingStatus {
  Confirm
  Confirmed
  Pending
  Cancelled
  CheckedIn
  CheckedOut
}

enum RoomTypeEnum {
  Single
  Double
  Triple
  Quard
  Suite
}

enum MealPlan {
  EP
  CP
  MAP
  AP
  EPKitchen
}

// ===== MODELS =====

// User Model with permissions
model User {
  id                  Int      @id @default(autoincrement())
  username            String   @unique @db.VarChar(50)
  password_hash       String   @db.VarChar(255)
  role                Role     @default(VIEWER)
  canViewAllBranches  Boolean  @default(false)
  canCreateBookings   Boolean  @default(true)
  email               String?  @db.VarChar(100)
  phone               String?  @db.VarChar(20)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  
  branches            UserBranch[]
  bookings            Booking[]
  notifications       Notification[]
  
  @@index([username])
}

// User Branches (Many-to-Many)
model UserBranch {
  id          Int      @id @default(autoincrement())
  user_id     Int
  branch_name String   @db.VarChar(100)
  
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@unique([user_id, branch_name])
  @@index([branch_name])
}

// Booking Model
model Booking {
  id                  String          @id @default(cuid())
  bookingNo           String          @unique
  agentName           String          @db.VarChar(100)
  agentContact        String          @db.VarChar(20)
  email               String?         @db.VarChar(100)
  roomsCount          Int             @default(1)
  roomType            RoomTypeEnum
  facility            String          @default("Standard") @db.VarChar(50)
  facilityMultiplier  Float           @default(1.0)
  price               Float?          @default(0)
  mealPlan            MealPlan        @default(EP)
  selfCooking         Boolean?        @default(false)
  checkIn             DateTime
  checkOut            DateTime
  nights              Int
  remark              String?         @db.Text
  branch              Branch
  bookingStatus       BookingStatus   @default(Confirm)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Pricing fields
  roomCharges         Float           @default(0)
  kitchenCharges      Float           @default(0)
  diningCharges       Float           @default(0)
  breakfastCharges    Float           @default(0)
  currency            String          @default("NPR") @db.VarChar(10)
  heads               Int             @default(1)
  extraPersonCharges  Float           @default(0)
  extraPersons        Int             @default(0)
  childrenCount       Int             @default(0)
  childrenBelow10     Int             @default(0)
  totalCost           Float           @default(0)
  
  roomCapacity        Int             @default(1)
  totalCapacity       Int             @default(1)

  // User tracking fields
  branchName          String?         @db.VarChar(100)
  createdBy           String?         @db.VarChar(50)
  createdByRole       String?         @db.VarChar(20)
  userRole            String?         @db.VarChar(20)
  createdByUsername   String?         @db.VarChar(50)
  creatorRole         String?         @db.VarChar(20)

  // Automation fields
  actualCheckIn       DateTime?       @map("actual_check_in")
  actualCheckOut      DateTime?       @map("actual_check_out")
  roomNumber          String?         @map("room_number") @db.VarChar(50)
  checkoutReminderSent Boolean        @default(false)     @map("checkout_reminder_sent")
  checkinReminderSent   Boolean       @default(false)     @map("checkin_reminder_sent")

  // Timestamps
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt

  // Relations
  feedback            Feedback?
  user                User?           @relation(fields: [userId], references: [id])
  userId              Int?            @map("user_id")
  notifications       Notification[]
  emailLogs           EmailLog[]
  roomAvailabilities  RoomAvailability[]
  bookingRooms        BookingRoom[]
  
  @@index([branch])
  @@index([branchName])
  @@index([checkIn])
  @@index([checkOut])
  @@index([bookingStatus])
  @@index([bookingNo])
  @@index([created_at])
  @@index([userId])
  @@index([createdBy])
  @@index([userRole])
  @@index([actualCheckIn])
  @@index([actualCheckOut])
  @@index([roomType])
  @@index([facility])
}

// Room Model
model Room {
  id          String   @id @default(cuid())
  roomNumber  String   @unique @db.VarChar(50)
  branch      Branch
  roomType    RoomTypeEnum
  capacity    Int      @default(1)
  status      String   @default("available") @db.VarChar(20)
  floor       String?  @db.VarChar(10)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  roomAvailabilities RoomAvailability[]
  bookingRooms       BookingRoom[]

  @@unique([branch, roomNumber])
  @@index([branch])
  @@index([roomType])
  @@index([status])
}

// Room Availability
model RoomAvailability {
  id          String   @id @default(cuid())
  roomId      String
  date        DateTime
  isAvailable Boolean  @default(true)
  bookingId   String?
  
  // Relations
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking     Booking? @relation(fields: [bookingId], references: [id])

  @@unique([roomId, date])
  @@index([date])
  @@index([isAvailable])
  @@index([bookingId])
}

// BookingRoom junction table
model BookingRoom {
  id          String   @id @default(cuid())
  bookingId   String
  roomId      String
  assignedAt  DateTime @default(now())
  
  // Relations
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([bookingId, roomId])
  @@index([bookingId])
  @@index([roomId])
}

// Branch Capacity
model BranchCapacity {
  id         String   @id @default(cuid())
  branch     Branch   @unique
  singleCap  Int      @default(0)
  doubleCap  Int      @default(0)
  tripleCap  Int      @default(0)
  quardCap   Int      @default(0)
  suiteCap   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([branch])
}

// Room Type Capacity
model RoomTypeCapacity {
  id              Int      @id @default(autoincrement())
  branch          Branch
  roomType        String   @db.VarChar(50)
  totalRooms      Int      @default(0)
  occupiedRooms   Int      @default(0)
  availableRooms  Int      @default(0)
  updated_at      DateTime @updatedAt
  
  @@unique([branch, roomType])
  @@index([branch, roomType])
}

// Room Types (Model)
model RoomTypeModel {
  id              Int      @id @default(autoincrement())
  name            String   @unique @db.VarChar(50)
  description     String?  @db.Text
  maxOccupancy    Int      @default(1)
  basePrice       Float    @default(0)
  isActive        Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  pricing         RoomPricing[]
  
  @@index([name])
  @@index([isActive])
}

// Room Pricing
model RoomPricing {
  id              Int      @id @default(autoincrement())
  branch          Branch
  roomType        String   @db.VarChar(50)
  season          String   @db.VarChar(50)
  basePrice       Float    @default(0)
  currentPrice    Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean  @default(true)
  createdBy       String   @db.VarChar(50)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  // Relations
  roomTypeRef     RoomTypeModel @relation(fields: [roomType], references: [name])
  
  @@unique([branch, roomType, season, startDate, endDate])
  @@index([branch, roomType])
  @@index([isActive])
  @@index([season])
}

// ✅ CORRECTED: Branch Room Pricing - Only these columns exist
model BranchRoomPricing {
  id                String   @id @default(cuid())
  branch            Branch   @unique
  singlePrice       Float    @default(2000)
  doublePrice       Float    @default(3000)
  triplePrice       Float    @default(4500)
  quardPrice        Float    @default(5500)
  suitePrice        Float    @default(8000)
  extraPersonPrice  Float    @default(500)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("branch_room_pricing")
}

// Pricing History
model PricingHistory {
  id              Int      @id @default(autoincrement())
  branch          Branch
  roomType        String   @db.VarChar(50)
  season          String   @db.VarChar(50)
  oldPrice        Float
  newPrice        Float
  changedBy       String   @db.VarChar(50)
  reason          String?  @db.Text
  created_at      DateTime @default(now())
  
  @@index([branch, roomType])
  @@index([created_at])
  @@index([season])
}

// Feedback
model Feedback {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  bookingNo   String   @db.VarChar(50)
  guestName   String   @db.VarChar(100)
  guestEmail  String   @db.VarChar(100)
  rating      Int
  review      String?  @db.Text
  stayDate    DateTime
  submittedAt DateTime @default(now())
  status      String   @default("pending") @db.VarChar(20)
  branch      Branch
  
  // Relations
  booking     Booking  @relation(fields: [bookingId], references: [id])
  
  @@index([bookingId])
  @@index([guestEmail])
  @@index([submittedAt])
  @@index([branch])
  @@index([status])
}

// Audit Log
model AuditLog {
  id         String   @id @default(cuid())
  username   String   @db.VarChar(50)
  branch     Branch?
  action     String   @db.VarChar(50)
  entity     String   @db.VarChar(50)
  entityId   String?  @db.VarChar(50)
  details    Json?
  ip         String?  @db.VarChar(50)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())
  
  @@index([username])
  @@index([branch])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

// Trial Signup
model TrialSignup {
  id         String   @id @default(cuid())
  email      String   @unique @db.VarChar(100)
  name       String   @db.VarChar(100)
  phone      String?  @db.VarChar(20)
  company    String?  @db.VarChar(100)
  password   String   @db.VarChar(255)
  branch     Branch   @default(Pokhara)
  status     String   @default("PENDING") @db.VarChar(20)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([email])
  @@index([status])
}

// Seasonal Pricing Rules
model SeasonalPricingRule {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  season          String   @db.VarChar(50)
  multiplier      Float    @default(1.0)
  startMonth      Int
  endMonth        Int
  isActive        Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  @@unique([season])
  @@index([season, isActive])
}

// Notification Model
model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  branch      Branch
  roomId      String?  @map("room_id")
  bookingId   String?  @map("booking_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  booking     Booking? @relation(fields: [bookingId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  userId      Int?     @map("user_id")

  @@map("notifications")
  @@index([branch])
  @@index([isRead])
  @@index([createdAt])
  @@index([type])
  @@index([bookingId])
  @@index([userId])
}

// Email Log Model
model EmailLog {
  id          String   @id @default(cuid())
  to          String   @db.VarChar(255)
  subject     String   @db.VarChar(255)
  template    String   @db.VarChar(100)
  data        Json
  status      String   @db.VarChar(20)
  sentAt      DateTime @map("sent_at")
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  booking     Booking? @relation(fields: [bookingId], references: [id])
  bookingId   String?  @map("booking_id")

  @@map("email_logs")
  @@index([to])
  @@index([status])
  @@index([sentAt])
  @@index([createdAt])
  @@index([bookingId])
}

// Automation Log Model
model AutomationLog {
  id          String   @id @default(cuid())
  type        String   @db.VarChar(50)
  branch      Branch
  bookingId   String?  @map("booking_id")
  status      String   @db.VarChar(20)
  message     String?  @db.Text
  details     Json?
  executedBy  String   @db.VarChar(50)
  executedAt  DateTime @default(now()) @map("executed_at")

  @@map("automation_logs")
  @@index([branch])
  @@index([type])
  @@index([status])
  @@index([executedAt])
  @@index([bookingId])
}
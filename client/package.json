{
  "name": "mahadev-client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max_old_space_size=4096 && next dev",
    "build": "set NODE_OPTIONS=--max_old_space_size=4096 && next build",
    "start": "set NODE_OPTIONS=--max_old_space_size=4096 && next start",
    "lint": "next lint",
    "clear": "if exist .next rd /s /q .next & if exist node_modules\\.cache rd /s /q node_modules\\.cache",
    "clean": "rm -rf .next && rm -rf node_modules/.cache",
    "clean:win": "if exist .next rd /s /q .next & if exist node_modules\\.cache rd /s /q node_modules\\.cache",
    "dev:clean": "npm run clean && npm run dev",
    "dev:clean:win": "npm run clean:win && npm run dev"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "chart.js": "^4.5.1",
    "date-fns": "^2.30.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-calendar": "^4.8.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
